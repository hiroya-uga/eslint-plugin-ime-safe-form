{
  "name": "eslint-plugin-ime-safe-form",
  "description": "ESLint plugin to enforce IME-safe form submission — requires e.isComposing guard or form submit event instead of Enter key detection in keydown/keyup handlers",
  "version": "1.0.3",
  "author": "Hiroya Uga",
  "bugs": {
    "url": "https://github.com/hiroya-uga/eslint-plugin-ime-safe-form/issues"
  },
  "devDependencies": {
    "@types/estree": "^1.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "homepage": "https://github.com/hiroya-uga/eslint-plugin-ime-safe-form#readme",
  "keywords": [
    "IME",
    "composition",
    "eslint",
    "eslint-plugin",
    "form",
    "isComposing",
    "submit",
    "enter",
    "keydown",
    "keyup",
    "react",
    "accessibility"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "commonjs",
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hiroya-uga/eslint-plugin-ime-safe-form.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "node --require tsx/cjs --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "types": "dist/index.d.ts"
}
